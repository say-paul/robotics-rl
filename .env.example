# Robot Deployment Package — environment overrides
#
# Copy to .env and fill in paths for your machine.
# These override the `variables` section in robot YAML configs.
# Actual environment variables (export FOO=bar) override both.

# Path to cloned GR00T-WholeBodyControl repo
# git clone https://github.com/NVlabs/GR00T-WholeBodyControl.git
GROOT_WBC_ROOT=/home/you/GR00T-WholeBodyControl

# Path to this project root
RDP_ROOT=/home/you/path/to/robotics-rl

# HuggingFace token (required for model downloads)
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
